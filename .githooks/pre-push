#!/bin/sh
#
# Pre-push hook: refuse direct pushes to master so changes go through a pull
# request (which is where CI runs). This is a LOCAL, opt-in safety net -- not
# server-side enforcement, and bypassable with `git push --no-verify`.
#
# Enable in a clone with:  git config core.hooksPath .githooks
#
protected_branch="refs/heads/master"

# git feeds "<local_ref> <local_sha> <remote_ref> <remote_sha>" lines on stdin.
while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_ref" = "$protected_branch" ]; then
        echo "BLOCKED: direct pushes to master are disabled by .githooks/pre-push." >&2
        echo "         Create a feature branch and open a pull request instead." >&2
        echo "         To bypass once: git push --no-verify" >&2
        exit 1
    fi
done

exit 0
